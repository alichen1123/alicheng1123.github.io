---
/**
 * 搜索结果页
 * /:lang/search?q=关键词
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import SeoHead from '../../components/SeoHead.astro';
import Sidebar from '../../components/Sidebar.astro';
import { isValidLang, SITE_URL, UI_TEXT, type SupportedLang } from '../../lib/env';
import { searchPosts, getPublicTags, getRecentPosts } from '../../lib/ghost';

const { lang } = Astro.params;

if (!lang || !isValidLang(lang)) {
  return Astro.redirect('/en', 302);
}

const currentLang = lang as SupportedLang;
const t = UI_TEXT[currentLang] || UI_TEXT.en;

const query = Astro.url.searchParams.get('q')?.trim() || '';
const posts = query ? await searchPosts(query, currentLang) : [];

const [tags, recentPosts] = await Promise.all([
  getPublicTags(currentLang),
  getRecentPosts(currentLang, 5),
]);

const pageTitle = `${t.searchTitle} - ${query || ''}`;

const seo = {
  title: pageTitle,
  description: pageTitle,
  canonicalUrl: `${SITE_URL}/${currentLang}/search`,
  ogTitle: pageTitle,
  ogDescription: pageTitle,
  ogImage: null,
  ogType: 'website',
  twitterCard: 'summary' as const,
  publishedTime: null,
  modifiedTime: null,
  author: null,
  lang: currentLang,
  slug: 'search',
};

Astro.response.headers.set('Cache-Control', 'no-cache');
---

<BaseLayout lang={currentLang} title={seo.title} hasSidebar={true}>
  <Fragment slot="head">
    <SeoHead seo={seo} jsonLdList={[]} />
  </Fragment>

  <h1 style="font-size: 1.75rem; margin-bottom: 1rem;">
    {t.searchTitle}
  </h1>

  <!-- 搜索框 -->
  <form action={`/${currentLang}/search`} method="get" class="search-form">
    <input
      type="text"
      name="q"
      value={query}
      placeholder={t.searchPlaceholder}
      class="search-input"
      autofocus
    />
    <button type="submit" class="search-submit">{t.searchBtn}</button>
  </form>

  {query && (
    <p class="search-result-count">
      {t.searchResultCount.replace('{count}', String(posts.length))}
    </p>
  )}

  {query && posts.length === 0 && (
    <p style="color: var(--color-text-light); margin-top: 1rem;">
      {t.searchNoResults}
    </p>
  )}

  <div class="post-list">
    {posts.map((post) => (
      <a href={`/${currentLang}/${post.slug}`} class="post-card">
        {post.feature_image && (
          <img src={post.feature_image} alt={post.title} loading="lazy" class="post-img" />
        )}
        <div class="post-info">
          <h2>{post.title}</h2>
          {post.custom_excerpt && <p>{post.custom_excerpt}</p>}
          <span class="post-meta">
            {post.reading_time || 1} {t.readingTime}
          </span>
        </div>
      </a>
    ))}
  </div>

  <Sidebar
    slot="sidebar"
    lang={currentLang}
    tags={tags}
    recentPosts={recentPosts}
    binanceUrl={Astro.locals.affiliate.binanceUrl}
  />
</BaseLayout>

<style>
  .search-form {
    display: flex;
    gap: 8px;
    margin-bottom: 1.5rem;
  }

  .search-input {
    flex: 1;
    padding: 10px 14px;
    font-size: 1rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    outline: none;
    transition: border-color 0.2s;
  }
  .search-input:focus {
    border-color: var(--color-primary);
  }

  .search-submit {
    padding: 10px 20px;
    font-size: 0.9rem;
    font-weight: 600;
    background: var(--color-primary);
    color: var(--color-text);
    border: none;
    border-radius: var(--radius);
    cursor: pointer;
    white-space: nowrap;
    transition: background 0.15s;
  }
  .search-submit:hover {
    background: var(--color-primary-dark);
  }

  .search-result-count {
    color: var(--color-text-light);
    font-size: 0.85rem;
    margin-bottom: 1rem;
  }

  .post-list {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .post-card {
    display: flex;
    gap: 16px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    overflow: hidden;
    text-decoration: none;
    color: var(--color-text);
    transition: box-shadow 0.2s;
  }
  .post-card:hover {
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    text-decoration: none;
  }

  .post-img {
    width: 200px;
    min-height: 130px;
    object-fit: cover;
    flex-shrink: 0;
  }

  .post-info {
    padding: 12px 16px 12px 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .post-info h2 {
    font-size: 1.1rem;
    line-height: 1.4;
    margin-bottom: 6px;
  }

  .post-info p {
    font-size: 0.85rem;
    color: var(--color-text-light);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin-bottom: 4px;
  }

  .post-meta {
    font-size: 0.75rem;
    color: var(--color-text-light);
  }

  @media (max-width: 640px) {
    .post-card {
      flex-direction: column;
    }
    .post-img {
      width: 100%;
      height: 180px;
    }
    .post-info {
      padding: 12px 16px;
    }
  }
</style>
