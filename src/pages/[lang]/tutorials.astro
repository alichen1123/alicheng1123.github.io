---
/**
 * 教程中心枢纽页（Topic Cluster Pillar Page）
 * /[lang]/tutorials
 * 聚合所有教程内容，按难度分级，按主题分类
 * 使用 Ghost 内部标签 #tutorial 筛选
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import SeoHead from '../../components/SeoHead.astro';
import Pagination from '../../components/Pagination.astro';
import Sidebar from '../../components/Sidebar.astro';
import { isValidLang, SITE_URL, UI_TEXT, CACHE_TTL, LIST_PAGE_SIZE, type SupportedLang } from '../../lib/env';
import { getPostList, getPublicTags, getRecentPosts } from '../../lib/ghost';
import { buildHubBreadcrumbJsonLd, buildOrganizationJsonLd } from '../../lib/seo';

const { lang } = Astro.params;

if (!lang || !isValidLang(lang)) {
  return Astro.redirect('/en', 302);
}

const currentLang = lang as SupportedLang;
const t = UI_TEXT[currentLang] || UI_TEXT.en;

const pageParam = Astro.url.searchParams.get('page');
const currentPage = Math.max(1, parseInt(pageParam || '1', 10) || 1);

// 按难度筛选
const difficultyParam = Astro.url.searchParams.get('level');

// 构建 Ghost tag filter：#tutorial + 可选难度
let tagFilter = 'hash-tutorial';
if (difficultyParam && ['beginner', 'intermediate', 'advanced'].includes(difficultyParam)) {
  tagFilter = `hash-tutorial+tag:${difficultyParam}`;
}

const [{ posts, total, pages: totalPages }, tags, recentPosts] = await Promise.all([
  getPostList({ lang: currentLang, page: currentPage, limit: LIST_PAGE_SIZE, tag: tagFilter }),
  getPublicTags(currentLang),
  getRecentPosts(currentLang, 5),
]);

if (currentPage > 1 && currentPage > totalPages && totalPages > 0) {
  return Astro.redirect(`/${currentLang}/tutorials`, 302);
}

const pageTitle = currentPage > 1
  ? `${t.tutorials} - ${t.page} ${currentPage} | 币易家`
  : `${t.tutorials} | 币易家`;

const canonicalUrl = currentPage > 1
  ? `${SITE_URL}/${currentLang}/tutorials?page=${currentPage}`
  : `${SITE_URL}/${currentLang}/tutorials`;

const seo = {
  title: pageTitle,
  description: t.tutorialsDesc,
  canonicalUrl,
  ogTitle: t.tutorials,
  ogDescription: t.tutorialsDesc,
  ogImage: null,
  ogType: 'website',
  twitterCard: 'summary' as const,
  publishedTime: null,
  modifiedTime: null,
  author: null,
  lang: currentLang,
  slug: 'tutorials',
};

const jsonLdList = [
  buildOrganizationJsonLd(),
  buildHubBreadcrumbJsonLd(currentLang, 'tutorials', t.tutorials),
];

const prevUrl = currentPage > 1
  ? currentPage === 2 ? `${SITE_URL}/${currentLang}/tutorials` : `${SITE_URL}/${currentLang}/tutorials?page=${currentPage - 1}`
  : null;
const nextUrl = currentPage < totalPages
  ? `${SITE_URL}/${currentLang}/tutorials?page=${currentPage + 1}`
  : null;

Astro.response.headers.set(
  'Cache-Control',
  `public, s-maxage=${CACHE_TTL.homeSMaxAge}, stale-while-revalidate=3600`
);

const difficultyLevels = [
  { key: '', label: t.allLevels },
  { key: 'beginner', label: t.beginner },
  { key: 'intermediate', label: t.intermediate },
  { key: 'advanced', label: t.advanced },
];
---

<BaseLayout lang={currentLang} title={seo.title} hasSidebar={true}>
  <Fragment slot="head">
    <SeoHead seo={seo} jsonLdList={jsonLdList} />
    {prevUrl && <link rel="prev" href={prevUrl} />}
    {nextUrl && <link rel="next" href={nextUrl} />}
  </Fragment>

  <nav class="hub-breadcrumb">
    <a href={`/${currentLang}`}>{t.home}</a>
    <span> / </span>
    <span>{t.tutorials}</span>
  </nav>

  <div class="hub-header">
    <h1>{t.tutorials}</h1>
    <p class="hub-desc">{t.tutorialsDesc}</p>
  </div>

  <!-- 难度筛选 -->
  <div class="difficulty-filter">
    {difficultyLevels.map((level) => (
      <a
        href={level.key ? `/${currentLang}/tutorials?level=${level.key}` : `/${currentLang}/tutorials`}
        class:list={['filter-btn', { active: (difficultyParam || '') === level.key }]}
      >
        {level.label}
      </a>
    ))}
  </div>

  {total > 0 && (
    <p class="hub-count">
      {currentLang === 'zh' ? `共 ${total} 篇教程` : `${total} ${t.totalArticles}`}
    </p>
  )}

  {posts.length === 0 && (
    <p style="color: var(--color-text-light); padding: 2rem 0;">
      {currentLang === 'zh' ? '暂无教程' : currentLang === 'es' ? 'No hay tutoriales' : 'No tutorials yet'}
    </p>
  )}

  <div class="post-list">
    {posts.map((post) => (
      <a href={`/${currentLang}/${post.slug}`} class="post-card">
        {post.feature_image && (
          <img src={post.feature_image} alt={post.title} loading="lazy" class="post-img" />
        )}
        <div class="post-info">
          <h2>{post.title}</h2>
          {post.custom_excerpt && <p>{post.custom_excerpt}</p>}
          <span class="post-meta">
            {post.reading_time || 1} {t.readingTime}
          </span>
        </div>
      </a>
    ))}
  </div>

  <Pagination
    currentPage={currentPage}
    totalPages={totalPages}
    baseUrl={`/${currentLang}/tutorials`}
  />

  <Sidebar
    slot="sidebar"
    lang={currentLang}
    tags={tags}
    recentPosts={recentPosts}
    binanceUrl={Astro.locals.affiliate.binanceUrl}
  />
</BaseLayout>

<style>
  .hub-breadcrumb {
    font-size: 0.82rem;
    color: var(--color-text-light);
    margin-bottom: 1rem;
  }
  .hub-breadcrumb a {
    color: var(--color-link);
    text-decoration: none;
  }

  .hub-header {
    margin-bottom: 1.5rem;
  }
  .hub-header h1 {
    font-size: 1.75rem;
    margin-bottom: 0.5rem;
  }
  .hub-desc {
    font-size: 0.9rem;
    color: var(--color-text-light);
    line-height: 1.6;
  }

  .difficulty-filter {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: 1.5rem;
  }

  .filter-btn {
    padding: 6px 16px;
    font-size: 0.82rem;
    font-weight: 500;
    border: 1px solid var(--color-border);
    border-radius: 100px;
    color: var(--color-text) !important;
    text-decoration: none !important;
    background: var(--color-bg);
    transition: all 0.15s;
  }
  .filter-btn:hover {
    border-color: var(--color-primary);
    background: var(--color-bg-light);
    text-decoration: none !important;
  }
  .filter-btn.active {
    background: var(--color-primary);
    border-color: var(--color-primary);
    font-weight: 700;
  }

  .hub-count {
    font-size: 0.85rem;
    color: var(--color-text-light);
    margin-bottom: 1rem;
  }

  .post-list { display: flex; flex-direction: column; gap: 16px; }
  .post-card { display: flex; gap: 16px; border: 1px solid var(--color-border); border-radius: var(--radius); overflow: hidden; text-decoration: none; color: var(--color-text); transition: box-shadow 0.2s; }
  .post-card:hover { box-shadow: 0 2px 8px rgba(0,0,0,0.08); text-decoration: none; }
  .post-img { width: 200px; min-height: 130px; object-fit: cover; flex-shrink: 0; }
  .post-info { padding: 12px 16px 12px 0; display: flex; flex-direction: column; justify-content: center; }
  .post-info h2 { font-size: 1.1rem; line-height: 1.4; margin-bottom: 6px; }
  .post-info p { font-size: 0.85rem; color: var(--color-text-light); display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; margin-bottom: 4px; }
  .post-meta { font-size: 0.75rem; color: var(--color-text-light); }
  @media (max-width: 640px) {
    .post-card { flex-direction: column; }
    .post-img { width: 100%; height: 180px; }
    .post-info { padding: 12px 16px; }
  }
</style>
