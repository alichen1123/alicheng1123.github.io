---
/**
 * 标签文章列表页（带分页）
 * /zh/tag/bitcoin, /en/tag/defi?page=2
 */
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SeoHead from '../../../components/SeoHead.astro';
import Pagination from '../../../components/Pagination.astro';
import Sidebar from '../../../components/Sidebar.astro';
import { isValidLang, SITE_URL, UI_TEXT, CACHE_TTL, LIST_PAGE_SIZE, type SupportedLang } from '../../../lib/env';
import { getPostList, getPublicTags, getRecentPosts } from '../../../lib/ghost';

const { lang, tag } = Astro.params;

if (!lang || !isValidLang(lang)) {
  return Astro.redirect('/en', 302);
}
if (!tag) {
  return Astro.redirect(`/${lang}`, 302);
}

const currentLang = lang as SupportedLang;
const t = UI_TEXT[currentLang] || UI_TEXT.en;

// 分页
const pageParam = Astro.url.searchParams.get('page');
const currentPage = Math.max(1, parseInt(pageParam || '1', 10) || 1);

// 获取数据
const [{ posts, total, pages: totalPages }, tags, recentPosts] = await Promise.all([
  getPostList({ lang: currentLang, page: currentPage, limit: LIST_PAGE_SIZE, tag }),
  getPublicTags(currentLang),
  getRecentPosts(currentLang, 5),
]);

// 页码越界
if (currentPage > 1 && currentPage > totalPages && totalPages > 0) {
  return Astro.redirect(`/${currentLang}/tag/${tag}`, 302);
}

// 找到当前 tag 的名称
const currentTagInfo = tags.find((t) => t.slug === tag);
const tagName = currentTagInfo?.name || tag;

// SEO
const pageTitle = currentPage > 1
  ? `${tagName} - ${t.page} ${currentPage} | 币易家`
  : `${tagName} | 币易家`;

const canonicalUrl = currentPage > 1
  ? `${SITE_URL}/${currentLang}/tag/${tag}?page=${currentPage}`
  : `${SITE_URL}/${currentLang}/tag/${tag}`;

const seo = {
  title: pageTitle,
  description: `${tagName} — ${total} ${t.totalArticles}`,
  canonicalUrl,
  ogTitle: pageTitle,
  ogDescription: `${tagName} — ${total} ${t.totalArticles}`,
  ogImage: null,
  ogType: 'website',
  twitterCard: 'summary' as const,
  publishedTime: null,
  modifiedTime: null,
  author: null,
  lang: currentLang,
  slug: `tag/${tag}`,
};

// prev/next
const prevUrl = currentPage > 1
  ? currentPage === 2
    ? `${SITE_URL}/${currentLang}/tag/${tag}`
    : `${SITE_URL}/${currentLang}/tag/${tag}?page=${currentPage - 1}`
  : null;
const nextUrl = currentPage < totalPages
  ? `${SITE_URL}/${currentLang}/tag/${tag}?page=${currentPage + 1}`
  : null;

Astro.response.headers.set(
  'Cache-Control',
  `public, s-maxage=${CACHE_TTL.homeSMaxAge}, stale-while-revalidate=3600`
);
---

<BaseLayout lang={currentLang} title={seo.title} hasSidebar={true}>
  <Fragment slot="head">
    <SeoHead seo={seo} jsonLdList={[]} />
    {prevUrl && <link rel="prev" href={prevUrl} />}
    {nextUrl && <link rel="next" href={nextUrl} />}
  </Fragment>

  <!-- 面包屑 -->
  <nav class="tag-breadcrumb">
    <a href={`/${currentLang}`}>{t.home}</a>
    <span> / </span>
    <span>{t.tagPageTitle}: {tagName}</span>
  </nav>

  <h1 class="tag-page-title">
    <span class="tag-label">{tagName}</span>
  </h1>

  {total > 0 && (
    <p style="color: var(--color-text-light); margin-bottom: 1rem; font-size: 0.85rem;">
      {currentLang === 'zh' ? `共 ${total} 篇文章` : `${total} ${t.totalArticles}`}
      {currentPage > 1 && (
        <span> · {t.page} {currentPage} / {totalPages}</span>
      )}
    </p>
  )}

  {posts.length === 0 && (
    <p style="color: var(--color-text-light);">
      {currentLang === 'zh' ? '该标签下暂无文章' : currentLang === 'es' ? 'No hay artículos con esta etiqueta' : 'No articles with this tag'}
    </p>
  )}

  <div class="post-list">
    {posts.map((post) => (
      <a href={`/${currentLang}/${post.slug}`} class="post-card">
        {post.feature_image && (
          <img src={post.feature_image} alt={post.title} loading="lazy" class="post-img" />
        )}
        <div class="post-info">
          <h2>{post.title}</h2>
          {post.custom_excerpt && <p>{post.custom_excerpt}</p>}
          <span class="post-meta">
            {post.reading_time || 1} {t.readingTime}
          </span>
        </div>
      </a>
    ))}
  </div>

  <Pagination
    currentPage={currentPage}
    totalPages={totalPages}
    baseUrl={`/${currentLang}/tag/${tag}`}
  />

  <Sidebar
    slot="sidebar"
    lang={currentLang}
    tags={tags}
    recentPosts={recentPosts}
    binanceUrl={Astro.locals.affiliate.binanceUrl}
    currentTag={tag}
  />
</BaseLayout>

<style>
  .tag-breadcrumb {
    font-size: 0.82rem;
    color: var(--color-text-light);
    margin-bottom: 1rem;
  }
  .tag-breadcrumb a {
    color: var(--color-link);
    text-decoration: none;
  }
  .tag-breadcrumb a:hover {
    text-decoration: underline;
  }

  .tag-page-title {
    font-size: 1.75rem;
    margin-bottom: 1rem;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .tag-label {
    background: var(--color-primary);
    padding: 4px 16px;
    border-radius: 6px;
    font-size: 1.5rem;
  }

  .post-list {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .post-card {
    display: flex;
    gap: 16px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    overflow: hidden;
    text-decoration: none;
    color: var(--color-text);
    transition: box-shadow 0.2s;
  }
  .post-card:hover {
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    text-decoration: none;
  }

  .post-img {
    width: 200px;
    min-height: 130px;
    object-fit: cover;
    flex-shrink: 0;
  }

  .post-info {
    padding: 12px 16px 12px 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .post-info h2 {
    font-size: 1.1rem;
    line-height: 1.4;
    margin-bottom: 6px;
  }

  .post-info p {
    font-size: 0.85rem;
    color: var(--color-text-light);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin-bottom: 4px;
  }

  .post-meta {
    font-size: 0.75rem;
    color: var(--color-text-light);
  }

  @media (max-width: 640px) {
    .post-card {
      flex-direction: column;
    }
    .post-img {
      width: 100%;
      height: 180px;
    }
    .post-info {
      padding: 12px 16px;
    }
  }
</style>
