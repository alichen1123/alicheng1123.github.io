---
/**
 * 作者档案页（E-E-A-T 合规）
 * /[lang]/author/[slug]
 * 展示作者资料 + 该作者的文章列表
 */
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SeoHead from '../../../components/SeoHead.astro';
import Pagination from '../../../components/Pagination.astro';
import Sidebar from '../../../components/Sidebar.astro';
import { isValidLang, SITE_URL, UI_TEXT, CACHE_TTL, LIST_PAGE_SIZE, type SupportedLang } from '../../../lib/env';
import { getAuthorBySlug, getPostsByAuthor, getPublicTags, getRecentPosts } from '../../../lib/ghost';
import { buildAuthorJsonLd, buildHubBreadcrumbJsonLd } from '../../../lib/seo';

const { lang, slug } = Astro.params;

if (!lang || !isValidLang(lang)) {
  return Astro.redirect('/en', 302);
}
if (!slug) {
  return Astro.redirect(`/${lang}`, 302);
}

const currentLang = lang as SupportedLang;
const t = UI_TEXT[currentLang] || UI_TEXT.en;

// 获取作者信息
const author = await getAuthorBySlug(slug);
if (!author) {
  return Astro.redirect('/404', 404);
}

// 分页
const pageParam = Astro.url.searchParams.get('page');
const currentPage = Math.max(1, parseInt(pageParam || '1', 10) || 1);

// 获取作者的文章 + 侧边栏数据
const [{ posts, total, pages: totalPages }, tags, recentPosts] = await Promise.all([
  getPostsByAuthor(slug, currentLang, currentPage, LIST_PAGE_SIZE),
  getPublicTags(currentLang),
  getRecentPosts(currentLang, 5),
]);

// SEO
const authorTitle = currentLang === 'zh' ? `${author.name} — 作者档案` :
  currentLang === 'es' ? `${author.name} — Perfil del autor` :
  `${author.name} — Author Profile`;

const pageTitle = currentPage > 1 ? `${authorTitle} - ${t.page} ${currentPage}` : `${authorTitle} | 币易家`;
const canonicalUrl = currentPage > 1
  ? `${SITE_URL}/${currentLang}/author/${slug}?page=${currentPage}`
  : `${SITE_URL}/${currentLang}/author/${slug}`;

const seo = {
  title: pageTitle,
  description: author.bio || `${author.name} — ${total} ${t.totalArticles}`,
  canonicalUrl,
  ogTitle: pageTitle,
  ogDescription: author.bio || `${author.name} — ${total} ${t.totalArticles}`,
  ogImage: author.profile_image,
  ogType: 'profile',
  twitterCard: 'summary' as const,
  publishedTime: null,
  modifiedTime: null,
  author: author.name,
  lang: currentLang,
  slug: `author/${slug}`,
};

const jsonLdList = [
  buildAuthorJsonLd(author, currentLang, total),
  buildHubBreadcrumbJsonLd(currentLang, `author/${slug}`, author.name),
];

Astro.response.headers.set(
  'Cache-Control',
  `public, s-maxage=${CACHE_TTL.homeSMaxAge}, stale-while-revalidate=3600`
);
---

<BaseLayout lang={currentLang} title={seo.title} hasSidebar={true}>
  <Fragment slot="head">
    <SeoHead seo={seo} jsonLdList={jsonLdList} />
  </Fragment>

  <!-- 面包屑 -->
  <nav class="author-breadcrumb">
    <a href={`/${currentLang}`}>{t.home}</a>
    <span> / </span>
    <span>{author.name}</span>
  </nav>

  <!-- 作者卡片 -->
  <div class="author-profile" itemscope itemtype="https://schema.org/Person">
    {author.profile_image && (
      <img
        src={author.profile_image}
        alt={author.name}
        class="author-avatar"
        itemprop="image"
        width="96"
        height="96"
      />
    )}
    <div class="author-info">
      <h1 itemprop="name">{author.name}</h1>
      {author.bio && (
        <p class="author-bio" itemprop="description">{author.bio}</p>
      )}
      <div class="author-stats">
        <span class="author-stat">
          {currentLang === 'zh' ? `${total} 篇文章` : `${total} ${t.totalArticles}`}
        </span>
        <span class="author-badge">
          {currentLang === 'zh' ? '认证作者' : currentLang === 'es' ? 'Autor verificado' : 'Verified Author'}
        </span>
      </div>
    </div>
  </div>

  <!-- 文章列表 -->
  <h2 class="author-articles-title">
    {currentLang === 'zh' ? '发表的文章' : currentLang === 'es' ? 'Artículos publicados' : 'Published Articles'}
  </h2>

  {posts.length === 0 && (
    <p style="color: var(--color-text-light);">
      {currentLang === 'zh' ? '暂无文章' : currentLang === 'es' ? 'No hay artículos' : 'No articles yet'}
    </p>
  )}

  <div class="post-list">
    {posts.map((post) => (
      <a href={`/${currentLang}/${post.slug}`} class="post-card">
        {post.feature_image && (
          <img src={post.feature_image} alt={post.title} loading="lazy" class="post-img" />
        )}
        <div class="post-info">
          <h3>{post.title}</h3>
          {post.custom_excerpt && <p>{post.custom_excerpt}</p>}
          <span class="post-meta">
            {post.reading_time || 1} {t.readingTime}
          </span>
        </div>
      </a>
    ))}
  </div>

  <Pagination
    currentPage={currentPage}
    totalPages={totalPages}
    baseUrl={`/${currentLang}/author/${slug}`}
  />

  <Sidebar
    slot="sidebar"
    lang={currentLang}
    tags={tags}
    recentPosts={recentPosts}
    binanceUrl={Astro.locals.affiliate.binanceUrl}
  />
</BaseLayout>

<style>
  .author-breadcrumb {
    font-size: 0.82rem;
    color: var(--color-text-light);
    margin-bottom: 1.5rem;
  }
  .author-breadcrumb a {
    color: var(--color-link);
    text-decoration: none;
  }
  .author-breadcrumb a:hover {
    text-decoration: underline;
  }

  .author-profile {
    display: flex;
    gap: 20px;
    align-items: flex-start;
    padding: 24px;
    background: var(--color-bg-light);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    margin-bottom: 2rem;
  }

  .author-avatar {
    width: 96px;
    height: 96px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
    border: 3px solid var(--color-primary);
  }

  .author-info {
    flex: 1;
    min-width: 0;
  }

  .author-info h1 {
    font-size: 1.5rem;
    margin-bottom: 8px;
    line-height: 1.3;
  }

  .author-bio {
    font-size: 0.9rem;
    color: var(--color-text-light);
    line-height: 1.6;
    margin-bottom: 10px;
  }

  .author-stats {
    display: flex;
    gap: 12px;
    align-items: center;
    flex-wrap: wrap;
  }

  .author-stat {
    font-size: 0.82rem;
    color: var(--color-text-light);
    font-weight: 500;
  }

  .author-badge {
    display: inline-block;
    background: linear-gradient(135deg, #f0b90b, #f7d060);
    color: #1a1a2e;
    font-size: 0.7rem;
    font-weight: 700;
    padding: 2px 10px;
    border-radius: 100px;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .author-articles-title {
    font-size: 1.25rem;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--color-primary);
  }

  /* Post list (reuse same styles as index/tag pages) */
  .post-list {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .post-card {
    display: flex;
    gap: 16px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    overflow: hidden;
    text-decoration: none;
    color: var(--color-text);
    transition: box-shadow 0.2s;
  }
  .post-card:hover {
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    text-decoration: none;
  }

  .post-img {
    width: 200px;
    min-height: 130px;
    object-fit: cover;
    flex-shrink: 0;
  }

  .post-info {
    padding: 12px 16px 12px 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .post-info h3 {
    font-size: 1.1rem;
    line-height: 1.4;
    margin-bottom: 6px;
  }

  .post-info p {
    font-size: 0.85rem;
    color: var(--color-text-light);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin-bottom: 4px;
  }

  .post-meta {
    font-size: 0.75rem;
    color: var(--color-text-light);
  }

  @media (max-width: 640px) {
    .author-profile {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }
    .author-stats {
      justify-content: center;
    }
    .post-card {
      flex-direction: column;
    }
    .post-img {
      width: 100%;
      height: 180px;
    }
    .post-info {
      padding: 12px 16px;
    }
  }
</style>
