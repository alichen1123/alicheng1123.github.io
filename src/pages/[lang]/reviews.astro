---
/**
 * 评测中心页
 * /[lang]/reviews
 * 聚合所有评测内容
 * 使用 Ghost 内部标签 #review 筛选
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import SeoHead from '../../components/SeoHead.astro';
import Pagination from '../../components/Pagination.astro';
import Sidebar from '../../components/Sidebar.astro';
import { isValidLang, SITE_URL, UI_TEXT, CACHE_TTL, LIST_PAGE_SIZE, type SupportedLang } from '../../lib/env';
import { getPostList, getPublicTags, getRecentPosts } from '../../lib/ghost';
import { buildHubBreadcrumbJsonLd, buildOrganizationJsonLd } from '../../lib/seo';

const { lang } = Astro.params;

if (!lang || !isValidLang(lang)) {
  return Astro.redirect('/en', 302);
}

const currentLang = lang as SupportedLang;
const t = UI_TEXT[currentLang] || UI_TEXT.en;

const pageParam = Astro.url.searchParams.get('page');
const currentPage = Math.max(1, parseInt(pageParam || '1', 10) || 1);

const [{ posts, total, pages: totalPages }, tags, recentPosts] = await Promise.all([
  getPostList({ lang: currentLang, page: currentPage, limit: LIST_PAGE_SIZE, tag: 'hash-review' }),
  getPublicTags(currentLang),
  getRecentPosts(currentLang, 5),
]);

if (currentPage > 1 && currentPage > totalPages && totalPages > 0) {
  return Astro.redirect(`/${currentLang}/reviews`, 302);
}

const pageTitle = currentPage > 1
  ? `${t.reviews} - ${t.page} ${currentPage} | 币易家`
  : `${t.reviews} | 币易家`;

const canonicalUrl = currentPage > 1
  ? `${SITE_URL}/${currentLang}/reviews?page=${currentPage}`
  : `${SITE_URL}/${currentLang}/reviews`;

const seo = {
  title: pageTitle,
  description: t.reviewsDesc,
  canonicalUrl,
  ogTitle: t.reviews,
  ogDescription: t.reviewsDesc,
  ogImage: null,
  ogType: 'website',
  twitterCard: 'summary' as const,
  publishedTime: null,
  modifiedTime: null,
  author: null,
  lang: currentLang,
  slug: 'reviews',
};

const jsonLdList = [
  buildOrganizationJsonLd(),
  buildHubBreadcrumbJsonLd(currentLang, 'reviews', t.reviews),
];

const prevUrl = currentPage > 1
  ? currentPage === 2 ? `${SITE_URL}/${currentLang}/reviews` : `${SITE_URL}/${currentLang}/reviews?page=${currentPage - 1}`
  : null;
const nextUrl = currentPage < totalPages
  ? `${SITE_URL}/${currentLang}/reviews?page=${currentPage + 1}`
  : null;

Astro.response.headers.set(
  'Cache-Control',
  `public, s-maxage=${CACHE_TTL.homeSMaxAge}, stale-while-revalidate=3600`
);
---

<BaseLayout lang={currentLang} title={seo.title} hasSidebar={true}>
  <Fragment slot="head">
    <SeoHead seo={seo} jsonLdList={jsonLdList} />
    {prevUrl && <link rel="prev" href={prevUrl} />}
    {nextUrl && <link rel="next" href={nextUrl} />}
  </Fragment>

  <nav class="hub-breadcrumb">
    <a href={`/${currentLang}`}>{t.home}</a>
    <span> / </span>
    <span>{t.reviews}</span>
  </nav>

  <div class="hub-header">
    <h1>{t.reviews}</h1>
    <p class="hub-desc">{t.reviewsDesc}</p>
  </div>

  {total > 0 && (
    <p class="hub-count">
      {currentLang === 'zh' ? `共 ${total} 篇评测` : `${total} ${t.totalArticles}`}
    </p>
  )}

  {posts.length === 0 && (
    <p style="color: var(--color-text-light); padding: 2rem 0;">
      {currentLang === 'zh' ? '暂无评测' : currentLang === 'es' ? 'No hay reseñas' : 'No reviews yet'}
    </p>
  )}

  <div class="review-grid">
    {posts.map((post) => (
      <a href={`/${currentLang}/${post.slug}`} class="review-card">
        {post.feature_image && (
          <img src={post.feature_image} alt={post.title} loading="lazy" class="review-img" />
        )}
        <div class="review-info">
          <h2>{post.title}</h2>
          {post.custom_excerpt && <p>{post.custom_excerpt}</p>}
          <span class="review-meta">
            {post.reading_time || 1} {t.readingTime}
          </span>
        </div>
      </a>
    ))}
  </div>

  <Pagination
    currentPage={currentPage}
    totalPages={totalPages}
    baseUrl={`/${currentLang}/reviews`}
  />

  <Sidebar
    slot="sidebar"
    lang={currentLang}
    tags={tags}
    recentPosts={recentPosts}
    binanceUrl={Astro.locals.affiliate.binanceUrl}
  />
</BaseLayout>

<style>
  .hub-breadcrumb { font-size: 0.82rem; color: var(--color-text-light); margin-bottom: 1rem; }
  .hub-breadcrumb a { color: var(--color-link); text-decoration: none; }
  .hub-header { margin-bottom: 1.5rem; }
  .hub-header h1 { font-size: 1.75rem; margin-bottom: 0.5rem; }
  .hub-desc { font-size: 0.9rem; color: var(--color-text-light); }
  .hub-count { font-size: 0.85rem; color: var(--color-text-light); margin-bottom: 1rem; }

  .review-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 16px; }
  .review-card { display: block; border: 1px solid var(--color-border); border-radius: var(--radius); overflow: hidden; text-decoration: none; color: var(--color-text); transition: box-shadow 0.2s; }
  .review-card:hover { box-shadow: 0 2px 8px rgba(0,0,0,0.08); text-decoration: none; }
  .review-img { width: 100%; height: 160px; object-fit: cover; }
  .review-info { padding: 14px 16px; }
  .review-info h2 { font-size: 1.05rem; line-height: 1.4; margin-bottom: 6px; }
  .review-info p { font-size: 0.85rem; color: var(--color-text-light); display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; margin-bottom: 4px; }
  .review-meta { font-size: 0.75rem; color: var(--color-text-light); }
</style>
