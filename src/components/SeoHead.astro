---
/**
 * SEO <head> 区块
 * 包含：meta tags、OG、Twitter Card、hreflang、JSON-LD
 */
import type { SeoMeta } from '../lib/seo';
import { buildHreflangList } from '../lib/seo';

interface Props {
  seo: SeoMeta;
  jsonLdList?: object[];
}

const { seo, jsonLdList = [] } = Astro.props;
const hreflangList = buildHreflangList(seo.slug);
---

<!-- 基础 SEO -->
<meta name="description" content={seo.description} />
<link rel="canonical" href={seo.canonicalUrl} />

<!-- GEO: AI 搜索引擎优化 meta -->
<meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
<meta name="generator" content="币易家" />

<!-- hreflang -->
{hreflangList.map((h) => (
  <link rel="alternate" hreflang={h.lang} href={h.url} />
))}

<!-- OpenGraph -->
<meta property="og:title" content={seo.ogTitle} />
<meta property="og:description" content={seo.ogDescription} />
<meta property="og:url" content={seo.canonicalUrl} />
<meta property="og:type" content={seo.ogType} />
<meta property="og:site_name" content="币易家" />
<meta property="og:locale" content={seo.lang === 'zh' ? 'zh_CN' : seo.lang === 'es' ? 'es_VE' : 'en_US'} />
{seo.ogImage && <meta property="og:image" content={seo.ogImage} />}
{seo.publishedTime && <meta property="article:published_time" content={seo.publishedTime} />}
{seo.modifiedTime && <meta property="article:modified_time" content={seo.modifiedTime} />}
{seo.author && <meta property="article:author" content={seo.author} />}

<!-- Twitter Card -->
<meta name="twitter:card" content={seo.twitterCard} />
<meta name="twitter:title" content={seo.ogTitle} />
<meta name="twitter:description" content={seo.ogDescription} />
{seo.ogImage && <meta name="twitter:image" content={seo.ogImage} />}

<!-- JSON-LD 结构化数据 -->
{jsonLdList.map((ld) => (
  <script type="application/ld+json" set:html={JSON.stringify(ld)} />
))}
