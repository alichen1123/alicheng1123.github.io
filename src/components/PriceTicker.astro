---
/**
 * 价格跑马灯组件
 * 放在导航栏正下方，显示实时币价走势
 * 悬停暂停 + 点击跳转币安对应交易对
 */
const BINANCE_REF = 'B2345';

// 少数币种在币安的交易对符号和 CoinGecko symbol 不一致，单独映射
// 大多数币种直接用 symbol.toUpperCase() 就对
const SYMBOL_MAP: Record<string, string> = {
  iota: 'IOTA',
  miota: 'IOTA',
  matic: 'POL',      // Polygon 已更名
  hbar: 'HBAR',
  kava: 'KAVA',
  celo: 'CELO',
  ont: 'ONT',
  qtum: 'QTUM',
  waves: 'WAVES',
  nano: 'XNO',
  xno: 'XNO',
  theta: 'THETA',
};
---

<div class="ticker-wrap" id="ticker-wrap">
  <div class="ticker-track" id="ticker-track">
    <!-- JS 动态填充 -->
    <span class="ticker-loading">Loading market data...</span>
  </div>
</div>

<style>
  .ticker-wrap {
    width: 100%;
    background: #0b0e11;
    overflow: hidden;
    height: 40px;
    display: flex;
    align-items: center;
    border-bottom: 1px solid #1e2329;
    position: relative;
    z-index: 99;
  }

  .ticker-track {
    display: flex;
    align-items: center;
    white-space: nowrap;
    animation: ticker-scroll 60s linear infinite;
    will-change: transform;
    gap: 0;
  }

  .ticker-wrap:hover .ticker-track {
    animation-play-state: paused;
  }

  @keyframes ticker-scroll {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  .ticker-item {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 0 22px;
    height: 40px;
    font-size: 0.78rem;
    font-weight: 600;
    color: #eaecef;
    text-decoration: none;
    border-right: 1px solid #1e2329;
    transition: background 0.15s;
    cursor: pointer;
    white-space: nowrap;
  }

  .ticker-item:hover {
    background: #1e2329;
    text-decoration: none;
  }

  .ticker-symbol {
    color: #eaecef;
    font-weight: 700;
    font-size: 0.88rem;
  }

  .ticker-price {
    color: #848e9c;
    font-size: 0.82rem;
    font-weight: 400;
  }

  .ticker-change {
    font-size: 0.85rem;
    font-weight: 700;
  }

  .ticker-change.up   { color: #0ecb81; }
  .ticker-change.down { color: #f6465d; }

  .ticker-loading {
    padding: 0 20px;
    font-size: 0.82rem;
    color: #848e9c;
  }
</style>

<script define:vars={{ BINANCE_REF, SYMBOL_MAP }}>
(function () {
  const track = document.getElementById('ticker-track');
  if (!track) return;

  function getBinanceSymbol(coinSymbol) {
    const lower = coinSymbol.toLowerCase();
    return SYMBOL_MAP[lower] || coinSymbol.toUpperCase();
  }

  function getBinanceUrl(coinSymbol) {
    const sym = getBinanceSymbol(coinSymbol);
    // 稳定币本身不需要 /USDT 对
    const stables = ['USDT','USDC','BUSD','DAI','TUSD','FDUSD'];
    if (stables.includes(sym)) {
      return `https://www.binance.com/markets/overview?ref=${BINANCE_REF}`;
    }
    return `https://www.binance.com/trade/${sym}_USDT?ref=${BINANCE_REF}`;
  }

  function formatPrice(price) {
    if (price >= 1000) return price.toLocaleString('en-US', { maximumFractionDigits: 0 });
    if (price >= 1)    return price.toFixed(2);
    if (price >= 0.01) return price.toFixed(4);
    return price.toFixed(6);
  }

  function renderTicker(coins) {
    // 取前 30 个币，双份拼接实现无缝循环
    const top = coins.slice(0, 30);
    const items = [...top, ...top].map((coin) => {
      const pct = coin.price_change_percentage_24h ?? 0;
      const isUp = pct >= 0;
      const sign = isUp ? '+' : '';
      const url = getBinanceUrl(coin.symbol);
      return `<a class="ticker-item" href="${url}" target="_blank" rel="noopener sponsored">
        <span class="ticker-symbol">${coin.symbol.toUpperCase()}</span>
        <span class="ticker-price">$${formatPrice(coin.current_price)}</span>
        <span class="ticker-change ${isUp ? 'up' : 'down'}">${sign}${pct.toFixed(2)}%</span>
      </a>`;
    }).join('');

    track.innerHTML = items;

    // 根据内容宽度动态调整滚动速度（每 px 约 0.015s）
    requestAnimationFrame(() => {
      const totalWidth = track.scrollWidth / 2;
      const duration = Math.max(30, totalWidth * 0.015);
      track.style.animationDuration = `${duration}s`;
    });
  }

  async function fetchAndRender() {
    try {
      const res = await fetch('/api/market');
      if (!res.ok) return;
      const coins = await res.json();
      if (Array.isArray(coins) && coins.length > 0) {
        renderTicker(coins);
      }
    } catch {
      // 静默失败
    }
  }

  fetchAndRender();
  setInterval(fetchAndRender, 60000);
})();
</script>
