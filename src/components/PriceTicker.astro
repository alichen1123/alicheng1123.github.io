---
/**
 * 价格跑马灯 — 纯文字风格，悬停暂停，点击跳转币安
 */
const BINANCE_REF = 'B2345';
const SYM_MAP = {
  matic: 'POL', iota: 'IOTA', miota: 'IOTA', nano: 'XNO', xno: 'XNO',
};
---

<div class="ticker-bar" id="ticker-bar">
  <div class="ticker-inner" id="ticker-inner">
    <span class="ticker-placeholder">Loading...</span>
  </div>
</div>

<style>
.ticker-bar {
  width: 100%;
  background: #0b0e11;
  height: 36px;
  overflow: hidden;
  border-bottom: 1px solid #1e2329;
  position: relative;
  z-index: 98;
  display: flex;
  align-items: center;
}

.ticker-inner {
  display: flex;
  align-items: center;
  white-space: nowrap;
  animation: ticker-move 80s linear infinite;
  will-change: transform;
}

.ticker-bar:hover .ticker-inner {
  animation-play-state: paused;
}

@keyframes ticker-move {
  0%   { transform: translateX(0); }
  100% { transform: translateX(-50%); }
}

.ticker-item {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  padding: 0 20px;
  height: 36px;
  text-decoration: none;
  border-right: 1px solid #1e2329;
  transition: background .12s;
  cursor: pointer;
}
.ticker-item:hover { background: #1a1f26; }

.t-sym {
  font-size: .8rem;
  font-weight: 700;
  color: #c9d1d9;
  letter-spacing: .02em;
}

.t-pct {
  font-size: .78rem;
  font-weight: 600;
}
.t-pct.up   { color: #0ecb81; }
.t-pct.down { color: #f6465d; }

.ticker-placeholder {
  padding: 0 16px;
  font-size: .78rem;
  color: #4a5568;
}
</style>

<script define:vars={{ BINANCE_REF, SYM_MAP }}>
(function(){
  const inner = document.getElementById('ticker-inner');
  if (!inner) return;

  function bSym(s){ return SYM_MAP[s.toLowerCase()] || s.toUpperCase(); }
  function bUrl(s){
    const sym = bSym(s);
    const st  = ['USDT','USDC','BUSD','DAI','TUSD','FDUSD'];
    return st.includes(sym)
      ? `https://www.binance.com/markets/overview?ref=${BINANCE_REF}`
      : `https://www.binance.com/trade/${sym}_USDT?ref=${BINANCE_REF}`;
  }

  function render(coins){
    const top  = coins.slice(0, 30);
    const rows = [...top, ...top]; // 双份无缝循环
    inner.innerHTML = rows.map(c => {
      const pct   = c.price_change_percentage_24h ?? 0;
      const up    = pct >= 0;
      const sign  = up ? '+' : '';
      const color = up ? '#0ecb81' : '#f6465d';
      const sym   = c.symbol.toUpperCase();
      const pctStr= sign + pct.toFixed(2) + '%';
      return `<a href="${bUrl(c.symbol)}" target="_blank" rel="noopener sponsored"
          style="display:inline-flex;align-items:center;gap:6px;padding:0 18px;height:36px;text-decoration:none;border-right:1px solid #1e2329;white-space:nowrap;transition:background .12s;cursor:pointer"
          onmouseenter="this.style.background='#1a1f26'"
          onmouseleave="this.style.background='transparent'">
        <span style="font-size:12px;font-weight:700;color:#c9d1d9;letter-spacing:.02em">${sym}</span>
        <span style="font-size:12px;font-weight:600;color:${color}">${pctStr}</span>
      </a>`;
    }).join('');

    // 动态调速
    requestAnimationFrame(() => {
      const w = inner.scrollWidth / 2;
      inner.style.animationDuration = Math.max(30, w * 0.014) + 's';
    });
  }

  async function load(){
    try{
      const r = await fetch('/api/market');
      if (!r.ok) return;
      const data = await r.json();
      if (Array.isArray(data) && data.length) render(data);
    }catch{}
  }

  load();
  setInterval(load, 60000);
})();
</script>
