---
import type { GhostTagWithCount, GhostPost } from '../lib/ghost';
import { UI_TEXT, type SupportedLang } from '../lib/env';
import TableOfContents from './TableOfContents.astro';
import Newsletter from './Newsletter.astro';

interface Props {
  lang: SupportedLang;
  tags: GhostTagWithCount[];
  recentPosts: GhostPost[];
  binanceUrl: string;
  currentTag?: string;
  outline?: string[];
}

const { lang, tags, recentPosts, binanceUrl, currentTag, outline } = Astro.props;
const t = UI_TEXT[lang] || UI_TEXT.en;

function relativeTime(dateStr: string): string {
  const now = Date.now();
  const diffMin = Math.floor((now - new Date(dateStr).getTime()) / 60000);
  if (diffMin < 1)  return lang === 'zh' ? '刚刚'        : lang === 'es' ? 'Ahora'            : 'Just now';
  if (diffMin < 60) return lang === 'zh' ? `${diffMin}分钟前` : lang === 'es' ? `Hace ${diffMin} min` : `${diffMin}m ago`;
  const h = Math.floor(diffMin / 60);
  if (h < 24)       return lang === 'zh' ? `${h}小时前`   : lang === 'es' ? `Hace ${h}h`       : `${h}h ago`;
  const d = Math.floor(h / 24);
  if (d < 30)       return lang === 'zh' ? `${d}天前`     : lang === 'es' ? `Hace ${d}d`       : `${d}d ago`;
  return new Date(dateStr).toLocaleDateString(lang === 'zh' ? 'zh-CN' : 'en-US', { month: 'short', day: 'numeric' });
}

const rankT  = lang === 'zh' ? '行情排行'  : lang === 'es' ? 'Ranking'   : 'Market Ranking';
const gainT  = lang === 'zh' ? '涨幅'      : lang === 'es' ? 'Subidas'   : 'Gainers';
const loseT  = lang === 'zh' ? '跌幅'      : lang === 'es' ? 'Bajadas'   : 'Losers';
const volT   = lang === 'zh' ? '成交'      : lang === 'es' ? 'Volumen'   : 'Volume';
const tradeT = lang === 'zh' ? '币安交易'  : lang === 'es' ? 'En Binance': 'Trade on Binance';
const affT   = lang === 'zh' ? '含推广链接 — 币安 ref. B2345' : 'Affiliate link — Binance ref. B2345';
const volLbl = lang === 'zh' ? '24h 成交额' : '24h Volume';
const rkLbl  = lang === 'zh' ? '市值排名'   : 'Market Cap Rank';
---

<aside class="sidebar">

  {outline && outline.length > 2 && <TableOfContents outline={outline} lang={lang} />}

  <!-- 行情排行 -->
  <div class="sidebar-card ranking-card">
    <h3 class="sidebar-title">{rankT}</h3>
    <div class="ranking-tabs">
      <button class="ranking-tab active" data-tab="gainers">▲ {gainT}</button>
      <button class="ranking-tab"        data-tab="losers" >▼ {loseT}</button>
      <button class="ranking-tab"        data-tab="volume" >⚡ {volT}</button>
    </div>
    <div class="ranking-list" data-cm="ranking-list">
      {[1,2,3,4,5,6,7].map(i => (
        <div class="ranking-item">
          <span class="rank-num">{i}</span>
          <span class="coin-avatar sk"></span>
          <span class="coin-meta">
            <span class="sk sk-sym"></span>
            <span class="sk sk-name"></span>
          </span>
          <span class="sk sk-pct"></span>
        </div>
      ))}
    </div>
  </div>

  <!-- 标签云 -->
  {tags.length > 0 && (
    <div class="sidebar-card">
      <h3 class="sidebar-title">{t.categories}</h3>
      <div class="tag-cloud">
        {tags.slice(0,20).map(tag => (
          <a href={`/${lang}/tag/${tag.slug}`}
             class:list={['sidebar-tag', { active: currentTag === tag.slug }]}>
            {tag.name}<span class="tag-count">{tag.count?.posts ?? 0}</span>
          </a>
        ))}
      </div>
    </div>
  )}

  <!-- 最近文章 -->
  {recentPosts.length > 0 && (
    <div class="sidebar-card">
      <h3 class="sidebar-title">{t.recentArticles}</h3>
      <div class="recent-list">
        {recentPosts.map(post => (
          <a href={`/${lang}/${post.slug}`} class="recent-item">
            {post.feature_image && (
              <img src={post.feature_image} alt={post.title} loading="lazy" class="recent-thumb" />
            )}
            <div class="recent-info">
              <span class="recent-title">{post.title}</span>
              <span class="recent-time">{relativeTime(post.published_at)}</span>
            </div>
          </a>
        ))}
      </div>
      <a href={`/${lang}`} class="sidebar-more">{t.viewAllArticles}</a>
    </div>
  )}

  <!-- CTA -->
  <div class="sidebar-card sidebar-cta">
    <strong>{lang === 'zh' ? '开始交易' : lang === 'es' ? 'Empieza a operar' : 'Start Trading'}</strong>
    <p>{lang === 'zh' ? '使用邀请码 B2345 注册币安，享手续费折扣'
      : lang === 'es' ? 'Regístrate en Binance con código B2345'
      : 'Sign up on Binance with code B2345 for fee discounts'}</p>
    <a href={binanceUrl} target="_blank" rel="noopener sponsored" class="sidebar-cta-btn">
      {lang === 'zh' ? '注册币安 →' : lang === 'es' ? 'Registrarse →' : 'Sign Up →'}
    </a>
  </div>

  <Newsletter lang={lang} variant="sidebar" />
</aside>

<!-- 浮层 -->
<div class="cm-overlay" data-cm="overlay">
  <div class="cm-box" data-cm="box">
    <button class="cm-x" data-cm="x">✕</button>

    <div class="cm-head">
      <img class="cm-logo" data-cm="logo" src="" alt="" />
      <div class="cm-head-text">
        <div class="cm-fullname" data-cm="fullname"></div>
        <div class="cm-badges">
          <span class="cm-badge" data-cm="sym"></span>
          <span class="cm-badge" data-cm="mcrank"></span>
        </div>
      </div>
    </div>

    <div class="cm-price-row">
      <span class="cm-price" data-cm="price"></span>
      <span class="cm-chg"   data-cm="chg"></span>
    </div>

    <div class="cm-grid">
      <div class="cm-cell">
        <span class="cm-cell-lbl" set:text={volLbl}></span>
        <span class="cm-cell-val" data-cm="vol"></span>
      </div>
      <div class="cm-cell">
        <span class="cm-cell-lbl" set:text={rkLbl}></span>
        <span class="cm-cell-val" data-cm="rank2"></span>
      </div>
    </div>

    <div class="cm-chart-box" data-cm="chart"></div>

    <a class="cm-trade" data-cm="trade" href="#" target="_blank" rel="noopener sponsored">
      {tradeT}
    </a>
    <p class="cm-aff">{affT}</p>
  </div>
</div>

<style>
/* ── 基础 ── */
.sidebar { display:flex; flex-direction:column; gap:20px; }

.sidebar-card {
  background: var(--color-bg);
  border: 1px solid var(--color-border);
  border-radius: var(--radius);
  padding: 16px;
}

.sidebar-title {
  font-size: .9rem;
  font-weight: 700;
  margin-bottom: 12px;
  padding-bottom: 8px;
  border-bottom: 2px solid var(--color-primary);
  color: var(--color-text);
}

/* ── 排行榜 ── */
.ranking-card { padding: 14px; }

.ranking-tabs {
  display: flex;
  gap: 3px;
  background: var(--color-bg-light);
  border-radius: 6px;
  padding: 3px;
  margin-bottom: 8px;
}

.ranking-tab {
  flex: 1;
  padding: 4px 0;
  font-size: .72rem;
  font-weight: 600;
  color: var(--color-text-light);
  background: none;
  border: none;
  border-radius: 4px;
  cursor: pointer;
  transition: all .15s;
  white-space: nowrap;
}
.ranking-tab.active {
  background: var(--color-bg);
  color: var(--color-text);
  box-shadow: 0 1px 3px rgba(0,0,0,.1);
}

.ranking-list { display: flex; flex-direction: column; }

.ranking-item {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 6px 4px;
  border-radius: 6px;
  cursor: pointer;
  transition: background .12s;
}
.ranking-item:hover { background: var(--color-bg-light); }

.rank-num {
  font-size: .7rem;
  font-weight: 600;
  color: var(--color-text-light);
  width: 14px;
  text-align: right;
  flex-shrink: 0;
}

/* 图标：小而精，26px */
.coin-avatar {
  width: 26px;
  height: 26px;
  border-radius: 50%;
  flex-shrink: 0;
  overflow: hidden;
  background: var(--color-bg-light);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: .6rem;
  font-weight: 700;
  color: var(--color-text-light);
}
.coin-avatar img {
  width: 26px;
  height: 26px;
  object-fit: cover;
  border-radius: 50%;
  display: block;
}

/* 文字区域 */
.coin-meta {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 1px;
}

.coin-sym {
  font-size: .8rem;
  font-weight: 700;
  color: var(--color-text);
  line-height: 1.2;
}

.coin-name {
  font-size: .68rem;
  color: var(--color-text-light);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* 涨跌幅 */
.coin-pct {
  font-size: .78rem;
  font-weight: 700;
  margin-left: auto;
  flex-shrink: 0;
  min-width: 52px;
  text-align: right;
}
.coin-pct.up   { color: #0ecb81; }
.coin-pct.down { color: #f6465d; }

/* 骨架屏 */
.sk {
  background: var(--color-border);
  border-radius: 4px;
  animation: skpulse 1.4s ease-in-out infinite;
}
.coin-avatar.sk { border-radius: 50%; }
.sk-sym  { display: block; width: 34px; height: 12px; }
.sk-name { display: block; width: 56px; height: 10px; margin-top: 3px; }
.sk-pct  { display: block; width: 44px; height: 12px; margin-left: auto; flex-shrink: 0; }

@keyframes skpulse {
  0%,100% { opacity: 1; }
  50%      { opacity: .35; }
}

/* ── 标签云 ── */
.tag-cloud { display: flex; flex-wrap: wrap; gap: 6px; }

.sidebar-tag {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  padding: 4px 10px;
  font-size: .8rem;
  color: var(--color-text) !important;
  background: var(--color-bg-light);
  border: 1px solid var(--color-border);
  border-radius: 4px;
  text-decoration: none !important;
  transition: all .15s;
}
.sidebar-tag:hover { border-color: var(--color-primary); }
.sidebar-tag.active {
  background: var(--color-primary);
  border-color: var(--color-primary);
  font-weight: 600;
}
.tag-count {
  font-size: .7rem;
  color: var(--color-text-light);
  background: var(--color-bg);
  border-radius: 3px;
  padding: 0 4px;
  min-width: 18px;
  text-align: center;
  line-height: 1.4;
}
.sidebar-tag.active .tag-count {
  background: rgba(255,255,255,.7);
  color: var(--color-text);
}

/* ── 最近文章 ── */
.recent-list { display: flex; flex-direction: column; }

.recent-item {
  display: flex;
  gap: 10px;
  padding: 10px 0;
  text-decoration: none !important;
  color: var(--color-text) !important;
  border-bottom: 1px solid var(--color-border);
}
.recent-item:last-child { border-bottom: none; }
.recent-item:hover .recent-title { color: var(--color-primary-dark); }

.recent-thumb { width: 60px; height: 45px; object-fit: cover; border-radius: 4px; flex-shrink: 0; }
.recent-info  { display: flex; flex-direction: column; justify-content: center; min-width: 0; }

.recent-title {
  font-size: .82rem;
  font-weight: 500;
  line-height: 1.35;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  transition: color .12s;
}
.recent-time { font-size: .72rem; color: var(--color-text-light); margin-top: 2px; }

.sidebar-more {
  display: block;
  text-align: center;
  margin-top: 10px;
  padding: 8px;
  font-size: .82rem;
  color: var(--color-link) !important;
  text-decoration: none !important;
  background: var(--color-bg-light);
  border-radius: 4px;
}

/* ── CTA ── */
.sidebar-cta {
  background: linear-gradient(135deg, #1a1a2e, #16213e);
  color: #fff;
  text-align: center;
  border: none;
}
.sidebar-cta strong { font-size: 1rem; display: block; margin-bottom: 6px; }
.sidebar-cta p { font-size: .8rem; opacity: .85; margin-bottom: 12px; line-height: 1.4; }
.sidebar-cta-btn {
  display: block;
  background: var(--color-primary);
  color: #1a1a2e !important;
  padding: 10px 16px;
  border-radius: 6px;
  font-weight: 700;
  font-size: .9rem;
  text-decoration: none !important;
  transition: background .15s;
}
.sidebar-cta-btn:hover { background: var(--color-primary-dark); }

/* ── 浮层 ── */
.cm-overlay {
  display: none;
  position: fixed;
  inset: 0;
  z-index: 1000;
  background: rgba(0,0,0,.6);
  align-items: center;
  justify-content: center;
  padding: 20px;
}
.cm-overlay.open { display: flex; }

.cm-box {
  position: relative;
  width: 100%;
  max-width: 340px;
  background: #12161c;
  border-radius: 16px;
  padding: 20px;
  color: #eaecef;
  animation: cmin .18s ease;
}
@keyframes cmin { from{transform:scale(.95);opacity:0} to{transform:scale(1);opacity:1} }

.cm-x {
  position: absolute;
  top: 14px; right: 14px;
  width: 26px; height: 26px;
  border-radius: 50%;
  background: #1e2329;
  border: none;
  color: #848e9c;
  font-size: .75rem;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background .15s;
}
.cm-x:hover { background: #2b3139; color: #eaecef; }

/* 头部 */
.cm-head {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 16px;
}
.cm-logo {
  width: 42px; height: 42px;
  border-radius: 50%;
  flex-shrink: 0;
  background: #1e2329;
}
.cm-fullname {
  font-size: .95rem;
  font-weight: 700;
  color: #eaecef;
  margin-bottom: 5px;
}
.cm-badges { display: flex; gap: 6px; }
.cm-badge {
  font-size: .7rem;
  font-weight: 500;
  color: #848e9c;
  background: #1e2329;
  padding: 2px 8px;
  border-radius: 4px;
}

/* 价格 */
.cm-price-row {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 14px;
}
.cm-price {
  font-size: 1.7rem;
  font-weight: 700;
  color: #eaecef;
  letter-spacing: -.02em;
}
.cm-chg {
  font-size: .82rem;
  font-weight: 700;
  padding: 3px 9px;
  border-radius: 6px;
}
.cm-chg.up   { background: rgba(14,203,129,.15); color: #0ecb81; }
.cm-chg.down { background: rgba(246,70,93,.15);  color: #f6465d; }

/* 数据格 */
.cm-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8px;
  margin-bottom: 14px;
}
.cm-cell {
  background: #1e2329;
  border-radius: 8px;
  padding: 9px 11px;
  display: flex;
  flex-direction: column;
  gap: 4px;
}
.cm-cell-lbl { font-size: .68rem; color: #848e9c; }
.cm-cell-val { font-size: .88rem; font-weight: 700; color: #eaecef; }

/* 走势图 */
.cm-chart-box {
  background: #1e2329;
  border-radius: 8px;
  height: 240px;
  overflow: hidden;
  margin-bottom: 14px;
}
.cm-chart-box iframe {
  width: 100%;
  height: 240px;
  border: none;
  display: block;
}

/* 交易按钮 */
.cm-trade {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  padding: 12px;
  background: #f0b90b;
  color: #1a1a2e !important;
  border-radius: 8px;
  font-size: .88rem;
  font-weight: 700;
  text-decoration: none !important;
  margin-bottom: 10px;
  transition: opacity .15s;
  box-sizing: border-box;
}
.cm-trade:hover { opacity: .88; }

.cm-aff {
  font-size: .62rem;
  color: #474d57;
  text-align: center;
  margin: 0;
}
</style>

<script>
(function(){
  const API = '/api/market';
  const API_FALLBACK = 'https://api.coingecko.com/api/v3/coins/markets?vs_currency=usd&order=market_cap_desc&per_page=100&sparkline=false&price_change_percentage=24h';
  let coins = [];
  let tab   = 'gainers';

  const listEl  = document.querySelector('[data-cm="ranking-list"]');
  const overlay = document.querySelector('[data-cm="overlay"]');
  const closeEl = document.querySelector('[data-cm="x"]');
  const BINANCE_REF = 'B2345';

  const SYM_MAP = {
    matic:'POL', iota:'IOTA', miota:'IOTA', nano:'XNO', xno:'XNO'
  };

  function bSym(s){ return SYM_MAP[s.toLowerCase()] || s.toUpperCase(); }

  function bUrl(s){
    const sym = bSym(s);
    const st  = ['USDT','USDC','BUSD','DAI','TUSD','FDUSD'];
    return st.includes(sym)
      ? 'https://www.binance.com/markets/overview?ref=' + BINANCE_REF
      : 'https://www.binance.com/trade/' + sym + '_USDT?ref=' + BINANCE_REF;
  }

  function fPrice(p){
    if (p >= 1000) return '$' + p.toLocaleString('en-US', {maximumFractionDigits:0});
    if (p >= 1)    return '$' + p.toFixed(2);
    if (p >= .01)  return '$' + p.toFixed(4);
    return '$' + p.toFixed(6);
  }

  function fVol(v){
    if (v >= 1e9) return '$' + (v/1e9).toFixed(2) + 'B';
    if (v >= 1e6) return '$' + (v/1e6).toFixed(2) + 'M';
    return '$' + (v/1e3).toFixed(1) + 'K';
  }

  document.querySelectorAll('.ranking-tab').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.ranking-tab').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      tab = btn.dataset.tab;
      render();
    });
  });

  function getList(){
    const v = coins.filter(c => c.price_change_percentage_24h != null);
    if (tab === 'gainers') return [...v].sort((a,b) => b.price_change_percentage_24h - a.price_change_percentage_24h).slice(0,7);
    if (tab === 'losers')  return [...v].sort((a,b) => a.price_change_percentage_24h - b.price_change_percentage_24h).slice(0,7);
    return [...coins].sort((a,b) => b.total_volume - a.total_volume).slice(0,7);
  }

  function render(){
    if (!listEl || !coins.length) return;
    listEl.innerHTML = getList().map((c, i) => {
      const pct  = c.price_change_percentage_24h ?? 0;
      const up   = pct >= 0;
      const disp = tab === 'volume' ? fVol(c.total_volume) : (up ? '+' : '') + pct.toFixed(2) + '%';
      const fb   = c.symbol.slice(0,2).toUpperCase();
      const pctColor = up ? '#0ecb81' : '#f6465d';
      return `<div data-rid="${c.id}" style="display:flex;align-items:center;gap:8px;padding:6px 4px;border-radius:6px;cursor:pointer;transition:background .12s"
                   onmouseenter="this.style.background='var(--color-bg-light)'"
                   onmouseleave="this.style.background='transparent'">
        <span style="font-size:11px;font-weight:600;color:var(--color-text-light);width:14px;text-align:right;flex-shrink:0">${i+1}</span>
        <span style="width:26px;height:26px;border-radius:50%;overflow:hidden;flex-shrink:0;background:var(--color-bg-light);display:flex;align-items:center;justify-content:center;font-size:9px;font-weight:700;color:var(--color-text-light)">
          <img src="${c.image}" alt="${c.symbol}"
               style="width:26px;height:26px;object-fit:cover;border-radius:50%;display:block"
               onerror="this.style.display='none';this.parentNode.textContent='${fb}'" />
        </span>
        <span style="flex:1;min-width:0;display:flex;flex-direction:column;gap:1px">
          <span style="font-size:12px;font-weight:700;color:var(--color-text);line-height:1.2">${c.symbol.toUpperCase()}</span>
          <span style="font-size:10px;color:var(--color-text-light);white-space:nowrap;overflow:hidden;text-overflow:ellipsis">${c.name}</span>
        </span>
        <span style="font-size:12px;font-weight:700;color:${pctColor};margin-left:auto;flex-shrink:0;min-width:48px;text-align:right">${disp}</span>
      </div>`;
    }).join('');

    listEl.querySelectorAll('[data-rid]').forEach(el => {
      el.addEventListener('click', () => {
        const c = coins.find(x => x.id === el.dataset.rid);
        if (c) openModal(c);
      });
    });
  }

  function openModal(c){
    const pct = c.price_change_percentage_24h ?? 0;
    const up  = pct >= 0;

    document.querySelector('[data-cm="logo"]').src           = c.image;
    document.querySelector('[data-cm="logo"]').alt           = c.name;
    document.querySelector('[data-cm="fullname"]').textContent = c.name;
    document.querySelector('[data-cm="sym"]').textContent     = c.symbol.toUpperCase();
    document.querySelector('[data-cm="mcrank"]').textContent  = '#' + c.market_cap_rank;
    document.querySelector('[data-cm="price"]').textContent   = fPrice(c.current_price);
    document.querySelector('[data-cm="vol"]').textContent     = fVol(c.total_volume);
    document.querySelector('[data-cm="rank2"]').textContent   = '#' + c.market_cap_rank;

    const chgEl = document.querySelector('[data-cm="chg"]');
    chgEl.textContent = (up ? '+' : '') + pct.toFixed(2) + '%';
    chgEl.className   = 'cm-chg ' + (up ? 'up' : 'down');

    document.querySelector('[data-cm="trade"]').href = bUrl(c.symbol);
    document.querySelector('[data-cm="trade"]').textContent =
      (document.documentElement.lang === 'zh' ? '币安交易 ' : 'Trade ')
      + c.symbol.toUpperCase() + '/USDT';

    const tvSym = 'BINANCE:' + bSym(c.symbol) + 'USDT';
    const chartEl = document.querySelector('[data-cm="chart"]');
    let currentPeriod = '1D';
    const periodMap = { '1D':'D', '1W':'W', '1M':'M', '3M':'3M' };

    function buildChartUrl(sym, interval) {
      return 'https://s.tradingview.com/widgetembed/?frameElementId=tv-iframe&symbol=' + sym +
        '&interval=' + interval + '&theme=dark&style=1&locale=en' +
        '&hide_top_toolbar=1&hide_legend=0&hide_side_toolbar=1' +
        '&allow_symbol_change=0&save_image=0&withdateranges=0&utm_source=biyijia.com';
    }

    function buildChart(sym, interval) {
      chartEl.innerHTML =
        '<div style="display:flex;gap:4px;padding:8px 10px 0;background:#1e2329">' +
        ['1D','1W','1M','3M'].map(p =>
          '<button data-period="' + p + '" style="padding:3px 10px;font-size:11px;font-weight:600;border-radius:4px;border:none;cursor:pointer;' +
          'background:' + (p === currentPeriod ? '#2b3139' : 'transparent') + ';' +
          'color:' + (p === currentPeriod ? '#eaecef' : '#848e9c') + ';transition:all .15s">' + p + '</button>'
        ).join('') +
        '</div>' +
        '<iframe data-frame="tv" src="' + buildChartUrl(sym, interval) + '" frameborder="0" allowtransparency="1" ' +
        'style="width:100%;height:200px;display:block;border:none" ' +
        'onerror="this.style.display=\\'none\\'"></iframe>' +
        '<div data-chart-err style="display:none;height:200px;align-items:center;justify-content:center;color:#848e9c;font-size:12px">暂无图表数据</div>';

      chartEl.querySelectorAll('button[data-period]').forEach(btn => {
        btn.addEventListener('click', () => {
          currentPeriod = btn.dataset.period;
          chartEl.querySelectorAll('button[data-period]').forEach(b => {
            b.style.background = b === btn ? '#2b3139' : 'transparent';
            b.style.color      = b === btn ? '#eaecef' : '#848e9c';
          });
          const frame = chartEl.querySelector('[data-frame="tv"]');
          if (frame) frame.src = buildChartUrl(sym, periodMap[currentPeriod] || 'D');
        });
      });

      // 5秒后检测 iframe 是否加载失败
      setTimeout(() => {
        const frame = chartEl.querySelector('[data-frame="tv"]');
        if (!frame) return;
        try {
          const doc = frame.contentDocument || frame.contentWindow.document;
          if (doc && doc.body && doc.body.innerText.includes('Try picking another')) {
            frame.style.display = 'none';
            const errDiv = chartEl.querySelector('[data-chart-err]');
            if (errDiv) errDiv.style.display = 'flex';
          }
        } catch(e) {}
      }, 5000);
    }

    buildChart(tvSym, 'D');

    overlay.classList.add('open');
    document.body.style.overflow = 'hidden';
  }

  function closeModal(){
    overlay.classList.remove('open');
    document.body.style.overflow = '';
    document.querySelector('[data-cm="chart"]').innerHTML = '';
  }

  closeEl.addEventListener('click', closeModal);
  overlay.addEventListener('click', e => { if (e.target === overlay) closeModal(); });
  document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });

  async function load(){
    try {
      let r = await fetch(API);
      if (!r.ok) throw new Error('proxy failed');
      coins = await r.json();
    } catch {
      try {
        const r2 = await fetch(API_FALLBACK);
        if (r2.ok) coins = await r2.json();
      } catch {}
    }
    render();
  }

  load();
  setInterval(load, 60000);
})();
</script>
